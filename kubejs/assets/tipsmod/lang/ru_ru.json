{"tipsmod.title.default":"\u0421\u043e\u0432\u0435\u0442","tip.tipsmod.undead_damage.text":"\u041d\u0435\u0436\u0438\u0442\u044c \u0432\u0440\u043e\u0434\u0435 \u0441\u043a\u0435\u043b\u0435\u0442\u043e\u0432 \u043f\u043e\u043b\u0443\u0447\u0430\u0435\u0442 \u0443\u0440\u043e\u043d \u043e\u0442 \u0437\u0435\u043b\u0438\u0439 \u043b\u0435\u0447\u0435\u043d\u0438\u044f \u0438 \u0438\u0441\u0446\u0435\u043b\u044f\u0435\u0442\u0441\u044f \u0437\u0435\u043b\u044c\u044f\u043c\u0438 \u0432\u0440\u0435\u0434\u0430.","tip.tipsmod.poison_immune.text":"\u0417\u043e\u043c\u0431\u0438, \u0441\u043a\u0435\u043b\u0435\u0442\u044b \u0438 \u043f\u0430\u0443\u043a\u0438 \u0438\u043c\u0435\u044e\u0442 \u0438\u043c\u043c\u0443\u043d\u0438\u0442\u0435\u0442 \u043a \u043e\u0442\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044e.","tip.tipsmod.witch_conversion.text":"\u0423\u0434\u0430\u0440 \u043c\u043e\u043b\u043d\u0438\u0438 \u043f\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0442 \u0436\u0438\u0442\u0435\u043b\u044f \u0432 \u0432\u0435\u0434\u044c\u043c\u0443.","tip.tipsmod.four_eggs.text":"\u0418\u0437 \u0440\u0430\u0437\u0431\u0438\u0442\u043e\u0433\u043e \u044f\u0439\u0446\u0430 \u0441 \u043e\u0447\u0435\u043d\u044c \u043d\u0438\u0437\u043a\u0438\u043c \u0448\u0430\u043d\u0441\u043e\u043c \u043c\u043e\u0436\u0435\u0442 \u0432\u044b\u043b\u0443\u043f\u0438\u0442\u044c\u0441\u044f \u0446\u0435\u043b\u044b\u0445 4 \u0446\u044b\u043f\u043b\u0451\u043d\u043a\u0430 \u0437\u0430 \u0440\u0430\u0437.","tip.tipsmod.nether_lava.text":"\u0412 \u041d\u0435\u0437\u0435\u0440\u0435 \u043b\u0430\u0432\u0430 \u0442\u0435\u0447\u0451\u0442 \u0431\u044b\u0441\u0442\u0440\u0435\u0435.","tip.tipsmod.west.text":"\u0421\u043e\u043b\u043d\u0446\u0435, \u043b\u0443\u043d\u0430 \u0438 \u0437\u0432\u0451\u0437\u0434\u044b \u0432\u0441\u0435\u0433\u0434\u0430 \u0434\u0432\u0438\u0436\u0443\u0442\u0441\u044f \u043d\u0430 \u0432\u043e\u0441\u0442\u043e\u043a.","tip.tipsmod.swamp_slime.text":"\u0421\u043b\u0438\u0437\u043d\u0438 \u043c\u043e\u0433\u0443\u0442 \u043f\u043e\u044f\u0432\u043b\u044f\u0442\u044c\u0441\u044f \u043d\u0430 \u0431\u043e\u043b\u043e\u0442\u0435 \u043f\u0440\u0438 \u043f\u043e\u043b\u043d\u043e\u0439 \u043b\u0443\u043d\u0435.","tip.tipsmod.deflect_ghast_fireballs.text":"\u0422\u044b \u043c\u043e\u0436\u0435\u0448\u044c \u043e\u0442\u0431\u0438\u0442\u044c \u043e\u0433\u043d\u0435\u043d\u043d\u044b\u0439 \u0448\u0430\u0440 \u0433\u0430\u0441\u0442\u0430, \u0443\u0434\u0430\u0440\u0438\u0432 \u043f\u043e \u043d\u0435\u043c\u0443.","tip.tipsmod.shulker_armor.text":"\u0428\u0430\u043b\u043a\u0435\u0440\u044b \u043f\u043e\u043b\u0443\u0447\u0430\u044e\u0442 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e \u0431\u043e\u043b\u044c\u0448\u0435 \u0443\u0440\u043e\u043d\u0430, \u043a\u043e\u0433\u0434\u0430 \u0438\u0445 \u043f\u0430\u043d\u0446\u0438\u0440\u0438 \u043e\u0442\u043a\u0440\u044b\u0442\u044b.","tip.tipsmod.arthropods.text":"\u041f\u0430\u0443\u043a\u0438, \u0447\u0435\u0448\u0443\u0439\u043d\u0438\u0446\u044b, \u043f\u0447\u0451\u043b\u044b \u0438 \u044d\u043d\u0434\u0435\u0440\u043c\u0438\u0442\u044b \u043f\u043e\u043b\u0443\u0447\u0430\u044e\u0442 \u0443\u0440\u043e\u043d \u043e\u0442 \u0437\u0430\u0447\u0430\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0411\u0438\u0447 \u0427\u043b\u0435\u043d\u0438\u0441\u0442\u043e\u043d\u043e\u0433\u0438\u0445.","tip.tipsmod.fossils.text":"\u041f\u043e\u0434 \u0431\u043e\u043b\u043e\u0442\u0430\u043c\u0438 \u0438 \u043f\u0443\u0441\u0442\u044b\u043d\u044f\u043c\u0438 \u043b\u0435\u0436\u0430\u0442 \u0438\u0441\u043a\u043e\u043f\u0430\u0435\u043c\u044b\u0435 \u043e\u0441\u0442\u0430\u043d\u043a\u0438.","tip.tipsmod.crouch_blocks.text":"\u041f\u0440\u0438\u0441\u0435\u0434\u0430\u0439, \u0447\u0442\u043e\u0431\u044b \u043d\u0435 \u0441\u0432\u0430\u043b\u0438\u0432\u0430\u0442\u044c\u0441\u044f \u0441 \u043a\u0440\u0430\u0451\u0432 \u0431\u043b\u043e\u043a\u043e\u0432.","tip.tipsmod.smoke_bees.text":"\u041f\u0447\u0451\u043b\u044b \u0441\u0442\u0430\u043d\u0443\u0442 \u0431\u0435\u0437\u043e\u0431\u0438\u0434\u043d\u044b\u043c\u0438, \u0435\u0441\u043b\u0438 \u0440\u0430\u0437\u043c\u0435\u0441\u0442\u0438\u0442\u044c \u043a\u043e\u0441\u0442\u0451\u0440 \u043f\u043e\u0434 \u0438\u0445 \u0443\u043b\u044c\u0435\u043c.","tip.tipsmod.lava_fuel.text":"\u0412\u0451\u0434\u0440\u0430 \u0441 \u043b\u0430\u0432\u043e\u0439 \u043c\u043e\u0436\u043d\u043e \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u043a\u0430\u043a \u0442\u043e\u043f\u043b\u0438\u0432\u043e \u0434\u043b\u044f \u043f\u0435\u0447\u0438.","tip.tipsmod.wooden_tool_fuel.text":"\u0421\u0442\u0430\u0440\u044b\u0435 \u0434\u0435\u0440\u0435\u0432\u044f\u043d\u043d\u044b\u0435 \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u044b \u043c\u043e\u0436\u043d\u043e \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u043a\u0430\u043a \u0442\u043e\u043f\u043b\u0438\u0432\u043e \u0434\u043b\u044f \u043f\u0435\u0447\u0438.","tip.tipsmod.scrap_nuggets.text":"\u0417\u043e\u043b\u043e\u0442\u044b\u0435 \u0438 \u0436\u0435\u043b\u0435\u0437\u043d\u044b\u0435 \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u044b/\u0431\u0440\u043e\u043d\u044e \u043c\u043e\u0436\u043d\u043e \u0440\u0430\u0441\u043f\u043b\u0430\u0432\u0438\u0442\u044c \u0438 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c \u0441\u0430\u043c\u043e\u0440\u043e\u0434\u043a\u0438.","tip.tipsmod.piglin_gold.text":"\u041f\u0438\u0433\u043b\u0438\u043d\u044b \u043e\u0447\u0435\u043d\u044c \u043b\u044e\u0431\u044f\u0442 \u0437\u043e\u043b\u043e\u0442\u043e.","tip.tipsmod.dog_health.text":"\u0427\u0435\u043c \u043d\u0438\u0436\u0435 \u0441\u043e\u0431\u0430\u043a\u0430 \u0434\u0435\u0440\u0436\u0438\u0442 \u0445\u0432\u043e\u0441\u0442, \u0442\u0435\u043c \u043c\u0435\u043d\u044c\u0448\u0435 \u0443 \u043d\u0435\u0451 \u043e\u0441\u0442\u0430\u043b\u043e\u0441\u044c \u0437\u0434\u043e\u0440\u043e\u0432\u044c\u044f.","tip.tipsmod.dog_rotten_flesh.text":"\u0422\u044b \u043c\u043e\u0436\u0435\u0448\u044c \u0432\u044b\u043b\u0435\u0447\u0438\u0442\u044c \u0441\u043e\u0431\u0430\u043a, \u043f\u043e\u043a\u043e\u0440\u043c\u0438\u0432 \u0438\u0445 \u0433\u043d\u0438\u043b\u043e\u0439 \u043f\u043b\u043e\u0442\u044c\u044e.","tip.tipsmod.lure_animals.text":"\u0422\u044b \u043c\u043e\u0436\u0435\u0448\u044c \u043f\u043e\u043c\u0430\u043d\u0438\u0442\u044c \u0436\u0438\u0432\u043e\u0442\u043d\u044b\u0445 \u0437\u0430 \u0441\u043e\u0431\u043e\u0439, \u0434\u0435\u0440\u0436\u0430 \u0435\u0434\u0443, \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u0438\u043c \u043d\u0440\u0430\u0432\u0438\u0442\u0441\u044f, \u0432 \u043e\u0441\u043d\u043e\u0432\u043d\u043e\u0439 \u0438\u043b\u0438 \u0432\u0441\u043f\u043e\u043c\u043e\u0433\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0439 \u0440\u0443\u043a\u0435.","tip.tipsmod.cooked_drops.text":"\u0421 \u0436\u0438\u0432\u043e\u0442\u043d\u044b\u0445, \u0443\u0431\u0438\u0442\u044b\u0445 \u043e\u0440\u0443\u0436\u0438\u0435\u043c \u0441 \u0417\u0430\u0433\u043e\u0432\u043e\u0440\u043e\u043c \u041e\u0433\u043d\u044f, \u0438\u043d\u043e\u0433\u0434\u0430 \u043f\u0430\u0434\u0430\u0435\u0442 \u043f\u0440\u043e\u0436\u0430\u0440\u0435\u043d\u043d\u0430\u044f \u0435\u0434\u0430.","tip.tipsmod.nether_sponge.text":"\u041c\u043e\u043a\u0440\u044b\u0435 \u0433\u0443\u0431\u043a\u0438 \u043c\u043e\u043c\u0435\u043d\u0442\u0430\u043b\u044c\u043d\u043e \u0432\u044b\u0441\u044b\u0445\u0430\u044e\u0442 \u0432 \u041d\u0435\u0437\u0435\u0440\u0435.","tip.tipsmod.boat_passenger.text":"\u041b\u043e\u0434\u043a\u0438 \u043c\u043e\u0433\u0443\u0442 \u043f\u0435\u0440\u0435\u0432\u043e\u0437\u0438\u0442\u044c \u0434\u043e \u0434\u0432\u0443\u0445 \u043f\u0430\u0441\u0441\u0430\u0436\u0438\u0440\u043e\u0432.","tip.tipsmod.note_block_instrument.text":"\u0418\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442, \u043a\u043e\u0442\u043e\u0440\u044b\u043c \u0431\u0443\u0434\u0435\u0442 \u043f\u0440\u043e\u0438\u0433\u0440\u0430\u043d \u0437\u0432\u0443\u043a, \u0437\u0430\u0432\u0438\u0441\u0438\u0442 \u043e\u0442 \u0442\u0438\u043f\u0430 \u0431\u043b\u043e\u043a\u0430, \u0440\u0430\u0441\u043f\u043e\u043b\u043e\u0436\u0435\u043d\u043d\u043e\u0433\u043e \u043f\u043e\u0434 \u043d\u043e\u0442\u043d\u044b\u043c \u0431\u043b\u043e\u043a\u043e\u043c.","tip.tipsmod.zombie_armor.text":"\u0417\u043e\u043c\u0431\u0438 \u0438\u043c\u0435\u044e\u0442 2 \u0431\u0430\u0437\u043e\u0432\u044b\u0445 \u043e\u0447\u043a\u0430 \u0431\u0440\u043e\u043d\u0438, \u0434\u0430\u0436\u0435 \u0435\u0441\u043b\u0438 \u043d\u0430 \u043d\u0438\u0445 \u043d\u0438\u0447\u0435\u0433\u043e \u043d\u0435 \u043d\u0430\u0434\u0435\u0442\u043e.","tip.tipsmod.undead_helmet.text":"\u0428\u043b\u0435\u043c \u0437\u0430\u0449\u0438\u0449\u0430\u0435\u0442 \u043d\u0435\u0436\u0438\u0442\u044c \u043e\u0442 \u0441\u0433\u043e\u0440\u0430\u043d\u0438\u044f \u043d\u0430 \u0441\u043e\u043b\u043d\u0446\u0435.","tip.tipsmod.iron_golem_heal.text":"\u0416\u0435\u043b\u0435\u0437\u043d\u044b\u0445 \u0433\u043e\u043b\u0435\u043c\u043e\u0432 \u043c\u043e\u0436\u043d\u043e \u0438\u0441\u0446\u0435\u043b\u0438\u0442\u044c, \u0435\u0441\u043b\u0438 \u0434\u0430\u0442\u044c \u0438\u043c \u0436\u0435\u043b\u0435\u0437\u043d\u044b\u0435 \u0441\u043b\u0438\u0442\u043a\u0438.","tip.tipsmod.turtle_shell.text":"\u0427\u0435\u0440\u0435\u043f\u0430\u0445\u0438 \u0441\u0431\u0440\u0430\u0441\u044b\u0432\u0430\u044e\u0442 \u0449\u0438\u0442\u043a\u0438 \u0441 \u043f\u0430\u043d\u0446\u0438\u0440\u044f \u043d\u0435 \u043f\u0440\u0438 \u0441\u043c\u0435\u0440\u0442\u0438, \u0430 \u043a\u043e\u0433\u0434\u0430 \u0432\u044b\u0440\u0430\u0441\u0442\u0430\u044e\u0442.","tip.tipsmod.animal_growing.text":"\u0422\u044b \u043c\u043e\u0436\u0435\u0448\u044c \u0443\u0441\u043a\u043e\u0440\u0438\u0442\u044c \u0440\u043e\u0441\u0442 \u0434\u0435\u0442\u0451\u043d\u044b\u0448\u0435\u0439, \u043f\u043e\u043a\u043e\u0440\u043c\u0438\u0432 \u0438\u0445.","tip.tipsmod.blaze_snowball.text":"\u0418\u0444\u0440\u0438\u0442\u044b \u2014 \u0435\u0434\u0438\u043d\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0435 \u0432\u0440\u0430\u0436\u0434\u0435\u0431\u043d\u044b\u0435 \u043c\u043e\u043d\u0441\u0442\u0440\u044b, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u043e\u043b\u0443\u0447\u0430\u044e\u0442 \u0443\u0440\u043e\u043d \u043e\u0442 \u0441\u043d\u0435\u0436\u043a\u043e\u0432.","tip.tipsmod.biome_bonemeal.text":"\u0418\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435 \u043a\u043e\u0441\u0442\u043d\u043e\u0439 \u043c\u0443\u043a\u0438 \u043d\u0430 \u0442\u0440\u0430\u0432\u0435 \u0432\u044b\u0440\u0430\u0449\u0438\u0432\u0430\u0435\u0442 \u0446\u0432\u0435\u0442\u044b. \u0412 \u0440\u0430\u0437\u043d\u044b\u0445 \u0431\u0438\u043e\u043c\u0430\u0445 \u0446\u0432\u0435\u0442\u044b \u0440\u0430\u0437\u043d\u044b\u0435.","tip.tipsmod.biome_fishing.text":"\u0420\u044b\u0431\u0430\u0447\u0430 \u0432 \u0434\u0436\u0443\u043d\u0433\u043b\u044f\u0445, \u043c\u043e\u0436\u043d\u043e \u0434\u043e\u0431\u044b\u0442\u044c \u043d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u0440\u0435\u0434\u043c\u0435\u0442\u044b, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043d\u0435 \u043b\u043e\u0432\u044f\u0442\u0441\u044f \u043d\u0438 \u0432 \u043e\u0434\u043d\u043e\u043c \u0434\u0440\u0443\u0433\u043e\u043c \u0431\u0438\u043e\u043c\u0435.","tip.tipsmod.creeper_cat.text":"\u041a\u0440\u0438\u043f\u0435\u0440\u044b \u0431\u043e\u044f\u0442\u0441\u044f \u043a\u043e\u0442\u043e\u0432 \u0438 \u0443\u0431\u0435\u0433\u0430\u044e\u0442 \u043e\u0442 \u043d\u0438\u0445.","tip.tipsmod.water_grass.text":"\u0421 \u043f\u043e\u043c\u043e\u0449\u044c\u044e \u0432\u043e\u0434\u044b \u043c\u043e\u0436\u043d\u043e \u0431\u044b\u0441\u0442\u0440\u043e \u043b\u043e\u043c\u0430\u0442\u044c \u0442\u0440\u0430\u0432\u0443 \u0434\u043b\u044f \u043f\u043e\u043b\u0443\u0447\u0435\u043d\u0438\u044f \u0441\u0435\u043c\u044f\u043d.","tip.tipsmod.gravity_torch.text":"\u0415\u0441\u043b\u0438 \u0431\u044b\u0441\u0442\u0440\u043e \u043f\u043e\u0441\u0442\u0430\u0432\u0438\u0442\u044c \u0444\u0430\u043a\u0435\u043b \u043f\u043e\u0434 \u043f\u0430\u0434\u0430\u044e\u0449\u0438\u043c\u0438 \u0431\u043b\u043e\u043a\u0430\u043c\u0438, \u043e\u043d\u0438 \u0432\u0441\u0435 \u0440\u0430\u0437\u0440\u0443\u0448\u0430\u0442\u0441\u044f.","tip.tipsmod.string_wool.text":"\u0427\u0442\u043e\u0431\u044b \u0441\u0434\u0435\u043b\u0430\u0442\u044c \u0448\u0435\u0440\u0441\u0442\u044c, \u043d\u0443\u0436\u043d\u043e \u0440\u0430\u0441\u043f\u043e\u043b\u043e\u0436\u0438\u0442\u044c \u043d\u0438\u0442\u0438 \u043a\u0432\u0430\u0434\u0440\u0430\u0442\u043e\u043c 2x2 \u0432 \u0432\u0435\u0440\u0441\u0442\u0430\u043a\u0435 \u0438\u043b\u0438 \u0441\u0435\u0442\u043a\u0435 \u043a\u0440\u0430\u0444\u0442\u0430.","tip.tipsmod.barrel.text":"\u0411\u043e\u0447\u043a\u0438 \u0431\u043e\u043b\u0435\u0435 \u044d\u0444\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u044b, \u0447\u0435\u043c \u0441\u0443\u043d\u0434\u0443\u043a\u0438: \u043e\u043d\u0438 \u043d\u0435 \u0442\u0440\u0435\u0431\u0443\u044e\u0442 \u043f\u0440\u043e\u0437\u0440\u0430\u0447\u043d\u043e\u0433\u043e \u0431\u043b\u043e\u043a\u0430 \u043d\u0430\u0434 \u0441\u043e\u0431\u043e\u0439 \u0438 \u0438\u0445 \u043c\u043e\u0436\u043d\u043e \u0441\u0442\u0430\u0432\u0438\u0442\u044c \u0440\u044f\u0434\u043e\u043c \u0431\u0435\u0441\u043a\u043e\u043d\u0435\u0447\u043d\u043e.","tip.tipsmod.job_site_dimension.text":"\u0416\u0438\u0442\u0435\u043b\u0438 \u0442\u0435\u0440\u044f\u044e\u0442 \u0441\u0432\u043e\u0438 \u0431\u043b\u043e\u043a\u0438 \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u0439, \u043f\u0435\u0440\u0435\u043c\u0435\u0449\u0430\u044f\u0441\u044c \u043c\u0435\u0436\u0434\u0443 \u0438\u0437\u043c\u0435\u0440\u0435\u043d\u0438\u044f\u043c\u0438.","tip.tipsmod.wandering_invis.text":"\u0421\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u0443\u044e\u0449\u0438\u0435 \u0442\u043e\u0440\u0433\u043e\u0432\u0446\u044b \u043d\u043e\u0447\u044c\u044e \u0432\u044b\u043f\u0438\u0432\u0430\u044e\u0442 \u0437\u0435\u043b\u044c\u044f \u043d\u0435\u0432\u0438\u0434\u0438\u043c\u043e\u0441\u0442\u0438.","tip.tipsmod.baby_panda_slimeball.text":"\u041c\u0430\u043b\u044b\u0448\u0438-\u043f\u0430\u043d\u0434\u044b \u043c\u043e\u0433\u0443\u0442 \u0432\u044b\u0447\u0438\u0445\u043d\u0443\u0442\u044c \u0448\u0430\u0440\u0438\u043a \u0441\u043b\u0438\u0437\u0438 \u0441 \u0448\u0430\u043d\u0441\u043e\u043c 0.1%.","tip.tipsmod.fortress_triangulation.text":"\u0420\u0430\u0441\u043f\u043e\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043a\u0440\u0435\u043f\u043e\u0441\u0442\u0438 \u043c\u043e\u0436\u043d\u043e \u0432\u044b\u0447\u0438\u0441\u043b\u0438\u0442\u044c, \u0437\u0430\u043f\u0443\u0441\u0442\u0438\u0432 \u041e\u043a\u043e \u042d\u043d\u0434\u0435\u0440\u0430 \u0438\u0437 \u0440\u0430\u0437\u043d\u044b\u0445 \u043c\u0435\u0441\u0442 \u0438 \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0438\u0432 \u0442\u043e\u0447\u043a\u0443 \u043f\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043d\u0438\u044f.","tip.tipsmod.creeper_drops_disc.text":"\u0415\u0441\u043b\u0438 \u0441\u0442\u0440\u0435\u043b\u0430 \u0441\u043a\u0435\u043b\u0435\u0442\u0430 \u0438\u043b\u0438 \u0437\u0438\u043c\u043e\u0433\u043e\u0440\u0430 \u0443\u0431\u0438\u0432\u0430\u0435\u0442 \u043a\u0440\u0438\u043f\u0435\u0440\u0430, \u0441 \u043d\u0435\u0433\u043e \u0432\u044b\u043f\u0430\u0434\u0435\u0442 \u0441\u043b\u0443\u0447\u0430\u0439\u043d\u0430\u044f \u043f\u043b\u0430\u0441\u0442\u0438\u043d\u043a\u0430 (\u043a\u0440\u043e\u043c\u0435 \u043e\u0434\u043d\u043e\u0439, \u0447\u0442\u043e \u0434\u043e\u0431\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u0432 \u041d\u0435\u0437\u0435\u0440\u0435).","tip.tipsmod.mooshroom_lightning.text":"\u0423\u0434\u0430\u0440 \u043c\u043e\u043b\u043d\u0438\u0438 \u043f\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0442 \u043a\u0440\u0430\u0441\u043d\u044b\u0439 \u0433\u0440\u0438\u0431 \u0432 \u043a\u043e\u0440\u0438\u0447\u043d\u0435\u0432\u044b\u0439, \u0430 \u043a\u043e\u0440\u0438\u0447\u043d\u0435\u0432\u044b\u0439 - \u0432 \u043a\u0440\u0430\u0441\u043d\u044b\u0439.","tip.tipsmod.bed_explode.text":"\u041f\u043e\u043f\u044b\u0442\u043a\u0430 \u043f\u043e\u0441\u043f\u0430\u0442\u044c \u0432 \u0434\u0440\u0443\u0433\u043e\u043c \u0438\u0437\u043c\u0435\u0440\u0435\u043d\u0438\u0438 \u0434\u043e\u0431\u0440\u043e\u043c \u043d\u0435 \u043a\u043e\u043d\u0447\u0438\u0442\u0441\u044f.","tip.tipsmod.fall_damage_blocks.text":"\u041d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0431\u043b\u043e\u043a\u0438 (\u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, \u0432\u043e\u0434\u0430 \u0438 \u0441\u0435\u043d\u043e) \u043c\u043e\u0433\u0443\u0442 \u0441\u043d\u0438\u0437\u0438\u0442\u044c \u0443\u0440\u043e\u043d \u043e\u0442 \u043f\u0430\u0434\u0435\u043d\u0438\u044f.","tip.tipsmod.bed_respawn.text":"\u0421\u043e\u043d \u0432 \u043a\u0440\u043e\u0432\u0430\u0442\u0438 \u0443\u0441\u0442\u0430\u043d\u0430\u0432\u043b\u0438\u0432\u0430\u0435\u0442 \u0442\u0432\u043e\u044e \u0442\u043e\u0447\u043a\u0443 \u0432\u043e\u0437\u0440\u043e\u0436\u0434\u0435\u043d\u0438\u044f.","tip.tipsmod.ore_tiers.text":"\u041d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0440\u0443\u0434\u044b \u043c\u043e\u0433\u0443\u0442 \u0431\u044b\u0442\u044c \u0434\u043e\u0431\u044b\u0442\u044b \u043b\u0438\u0448\u044c \u0434\u043e\u0441\u0442\u0430\u0442\u043e\u0447\u043d\u043e \u043c\u043e\u0449\u043d\u044b\u043c\u0438 \u043a\u0438\u0440\u043a\u0430\u043c\u0438.","tip.tipsmod.sponge_bucket.text":"\u041c\u043e\u043a\u0440\u0443\u044e \u0433\u0443\u0431\u043a\u0443 \u043c\u043e\u0436\u043d\u043e \u0432\u044b\u0441\u0443\u0448\u0438\u0442\u044c, \u043f\u0440\u0438\u0433\u043e\u0442\u043e\u0432\u0438\u0432 \u0435\u0451 \u0432 \u043f\u0435\u0447\u0438. \u0415\u0441\u043b\u0438 \u0432 \u0442\u043e\u043f\u043b\u0438\u0432\u043d\u043e\u043c \u0441\u043b\u043e\u0442\u0435 \u043f\u0435\u0447\u0438 \u0435\u0441\u0442\u044c \u043f\u0443\u0441\u0442\u043e\u0435 \u0432\u0435\u0434\u0440\u043e, \u0442\u043e \u043e\u043d\u043e \u0431\u0443\u0434\u0435\u0442 \u043d\u0430\u043f\u043e\u043b\u043d\u0435\u043d\u043e \u0432\u043e\u0434\u043e\u0439!","tip.tipsmod.coarse_to_dirt.text":"\u041a\u0430\u043c\u0435\u043d\u0438\u0441\u0442\u0443\u044e \u0437\u0435\u043c\u043b\u044e \u043c\u043e\u0436\u043d\u043e \u043f\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0442\u044c \u0432 \u043e\u0431\u044b\u0447\u043d\u0443\u044e, \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u044f \u043c\u043e\u0442\u044b\u0433\u0443.","tip.tipsmod.enderman_blocks.text":"\u042d\u043d\u0434\u0435\u0440\u043c\u0435\u043d \u043c\u043e\u0436\u0435\u0442 \u0442\u0430\u0441\u043a\u0430\u0442\u044c \u0431\u043b\u043e\u043a\u0438 \u2014 \u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, \u0437\u0435\u043c\u043b\u044e, \u043f\u0435\u0441\u043e\u043a \u0438 \u0434\u0438\u043d\u0430\u043c\u0438\u0442!","tip.tipsmod.piglin_repellent.text":"\u041f\u0438\u0433\u043b\u0438\u043d\u044b \u0431\u043e\u044f\u0442\u0441\u044f \u043e\u0433\u043d\u044f \u0434\u0443\u0448, \u0432 \u0442\u043e\u043c \u0447\u0438\u0441\u043b\u0435 \u0432 \u0432\u0438\u0434\u0435 \u0444\u043e\u043d\u0430\u0440\u0435\u0439 \u0438 \u0444\u0430\u043a\u0435\u043b\u043e\u0432.","tip.tipsmod.portal_trick.text":"\u041f\u043e\u0440\u0442\u0430\u043b \u0432 \u041d\u0435\u0437\u0435\u0440 \u043b\u0435\u0433\u043a\u043e \u0441\u0434\u0435\u043b\u0430\u0442\u044c \u0441 \u043f\u043e\u043c\u043e\u0449\u044c\u044e \u0432\u0451\u0434\u0435\u0440 \u0441 \u0432\u043e\u0434\u043e\u0439 \u0438 \u043b\u0430\u0432\u043e\u0439.","tip.tipsmod.blaze_fuel.text":"\u0421\u0442\u0440\u0435\u0436\u043d\u0438 \u0438\u0444\u0440\u0438\u0442\u0430 \u2014 \u043e\u0442\u043b\u0438\u0447\u043d\u043e\u0435 \u0442\u043e\u043f\u043b\u0438\u0432\u043e \u0434\u043b\u044f \u043f\u0435\u0447\u0435\u043a.","tip.tipsmod.goat_milk.text":"\u041a\u043e\u0437\u0443 \u043c\u043e\u0436\u043d\u043e \u043f\u043e\u0434\u043e\u0438\u0442\u044c \u0441 \u043f\u043e\u043c\u043e\u0449\u044c\u044e \u0432\u0435\u0434\u0440\u0430.","tip.tipsmod.mean_goats.text":"\u0411\u0443\u0434\u044c\u0442\u0435 \u043e\u0441\u0442\u043e\u0440\u043e\u0436\u043d\u044b \u0441 \u043a\u043e\u0437\u0430\u043c\u0438, \u043e\u043d\u0438 \u043b\u044e\u0431\u044f\u0442 \u0441\u0442\u0430\u043b\u043a\u0438\u0432\u0430\u0442\u044c \u0438\u0433\u0440\u043e\u043a\u043e\u0432 \u0438 \u0434\u0440\u0443\u0433\u0438\u0445 \u0436\u0438\u0432\u043e\u0442\u043d\u044b\u0445 \u0441\u043e \u0441\u043a\u0430\u043b.","tip.tipsmod.dripstone_lava.text":"\u0418\u0437 \u043a\u0430\u043f\u0435\u043b\u044c\u043d\u0438\u043a\u0430 \u043f\u043e\u0434 \u043b\u0430\u0432\u043e\u0439 \u0431\u0443\u0434\u0443\u0442 \u043c\u0435\u0434\u043b\u0435\u043d\u043d\u043e \u043a\u0430\u043f\u0430\u0442\u044c \u0447\u0430\u0441\u0442\u0438\u0446\u044b \u043b\u0430\u0432\u044b. \u042d\u0442\u043e \u043c\u043e\u0436\u0435\u0442 \u0431\u044b\u0442\u044c \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u043e \u0434\u043b\u044f \u0437\u0430\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u044f \u043a\u043e\u0442\u043b\u0430.","tip.tipsmod.bucket_friends.text":"\u0420\u044b\u0431\u0443 \u0438 \u0430\u043a\u0441\u043e\u043b\u043e\u0442\u043b\u0435\u0439 \u043c\u043e\u0436\u043d\u043e \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e \u0441\u043e\u0431\u0438\u0440\u0430\u0442\u044c \u0441 \u043f\u043e\u043c\u043e\u0449\u044c\u044e \u0432\u0451\u0434\u0435\u0440.","tip.tipsmod.bucket_rename.text":"\u041f\u0435\u0440\u0435\u0438\u043c\u0435\u043d\u043e\u0432\u0430\u043d\u0438\u0435 \u0432\u0435\u0434\u0440\u0430 \u0441 \u043c\u043e\u0431\u043e\u043c \u0432\u043d\u0443\u0442\u0440\u0438 \u0442\u0430\u043a\u0436\u0435 \u043f\u0435\u0440\u0435\u0438\u043c\u0435\u043d\u0443\u0435\u0442 \u044d\u0442\u043e\u0433\u043e \u0