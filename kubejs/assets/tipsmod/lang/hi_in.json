d.mushroom_placement.text":"\u0917\u0947\u0902\u0926\u094b\u0902 \u0915\u094b \u0915\u0947\u0935\u0932 \u0910\u0938\u0947 \u092c\u094d\u0932\u0949\u0915\u094b\u0902 \u092a\u0930 \u0930\u0916\u093e \u091c\u093e \u0938\u0915\u0924\u093e \u0939\u0948 \u091c\u0939\u093e\u0902 \u0938\u0940\u0927\u0947 \u0938\u0942\u0930\u091c \u0915\u0940 \u0930\u094b\u0936\u0928\u0940 \u0928\u0939\u0940\u0902 \u0939\u0948\u0964","tip.tipsmod.mushroom_biome_spawns.text":"\u0926\u0941\u0936\u094d\u092e\u0928\u094b\u0902 \u0915\u0940 \u092d\u0940\u0921\u093c\u0947\u0902 \u090f\u0915 \u092e\u0936\u0930\u0942\u092e \u092c\u093e\u092f\u094b\u092e \u092e\u0947\u0902 \u091c\u0928\u094d\u092e \u0928\u0939\u0940\u0902 \u0926\u0947 \u0938\u0915\u0924\u0940 \u0939\u0948\u0902\u0964","tip.tipsmod.shear_mooshroom.text":"\u0906\u092a \u090f\u0915 \u092e\u094b\u0936\u0930\u0942\u092e \u0915\u094b \u090f\u0915 \u0938\u093e\u092e\u093e\u0928\u094d\u092f \u0917\u093e\u092f \u092e\u0947\u0902 \u092c\u0926\u0932 \u0938\u0915\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.peaceful_tnt.text":"\u091f\u0940\u090f\u0928\u091f\u0940 \u0936\u093e\u0902\u0924\u093f\u092a\u0942\u0930\u094d\u0923 \u092e\u094b\u0921 \u092e\u0947\u0902 \u0916\u093f\u0932\u093e\u0921\u093c\u093f\u092f\u094b\u0902 \u0915\u094b \u0928\u0941\u0915\u0938\u093e\u0928 \u0928\u0939\u0940\u0902 \u092a\u0939\u0941\u0902\u091a\u093e \u0938\u0915\u0924\u0940 \u0939\u0948\u0964","tip.tipsmod.weather_sleep.text":"\u0928\u0940\u0902\u0926 \u0906\u0938\u092e\u093e\u0928 \u0915\u094b \u0938\u093e\u092b \u0915\u0930 \u0926\u0947\u0917\u0940 \u0914\u0930 \u0924\u0942\u092b\u093e\u0928 \u092f\u093e \u092c\u093e\u0930\u093f\u0936 \u0915\u094b \u0930\u094b\u0915 \u0926\u0947\u0917\u0940\u0964"}