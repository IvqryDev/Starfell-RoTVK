{"tipsmod.title.default":"\u091f\u0940\u092a","tip.tipsmod.undead_damage.text":"\u0938\u094d\u0915\u0947\u0932\u0947\u0902\u091f\u094d\u0938 \u091c\u0948\u0938\u0947 \u0905\u0935\u093f\u0928\u093e\u0936\u094b\u0902 \u0915\u094b \u0938\u094d\u0935\u093e\u0938\u094d\u0925\u094d\u092f \u092a\u0947\u092f \u0926\u094d\u0935\u093e\u0930\u093e \u0915\u094d\u0937\u0924\u093f\u0917\u094d\u0930\u0938\u094d\u0924 \u0915\u093f\u092f\u093e \u091c\u093e\u0924\u093e \u0939\u0948 \u0914\u0930 \u0928\u0941\u0915\u0938\u093e\u0928 \u092a\u0947\u092f \u0926\u094d\u0935\u093e\u0930\u093e \u0920\u0940\u0915 \u0915\u093f\u092f\u093e \u091c\u093e\u0924\u093e \u0939\u0948\u0964","tip.tipsmod.poison_immune.text":"\u091c\u0942\u092e\u092c\u0941\u0915, \u0938\u094d\u0915\u0947\u0932\u0947\u091f\u094d\u0938, \u0914\u0930 \u092e\u0915\u0921\u093c\u0940 \u0938\u092d\u0940 \u091c\u0939\u0930 \u0915\u094d\u0937\u0924\u093f \u0938\u0947 \u092a\u094d\u0930\u0924\u093f\u0930\u094b\u0927\u0940 \u0939\u0948\u0902\u0964","tip.tipsmod.witch_conversion.text":"\u0917\u093e\u0901\u0935 \u0915\u0947 \u0932\u094b\u0917 \u0930\u094b\u0936\u0928\u0940 \u0938\u0947 \u092e\u093e\u0930\u0947 \u091c\u093e\u0928\u0947 \u092a\u0930 \u091c\u093e\u0926\u0942\u0917\u0930 \u092c\u0928 \u091c\u093e\u090f\u0902\u0917\u0947\u0964","tip.tipsmod.four_eggs.text":"\u092c\u091a\u094d\u091a\u0947 \u0915\u0947 \u0905\u0902\u0921\u0947 \u0915\u093e\u091f\u0928\u0947 \u0938\u0947 \u092c\u0939\u0941\u0924 \u0939\u0940 \u0926\u0941\u0930\u094d\u0932\u092d \u0905\u0935\u0938\u0930\u094b\u0902 \u092a\u0930 \u091a\u093e\u0930 \u091a\u093f\u0915\u0928 \u092a\u0948\u0926\u093e \u0939\u094b \u0938\u0915\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.nether_lava.text":"\u0932\u0947\u0935\u093e \u0928\u0947\u091f\u0935\u0930\u094d\u0915 \u092e\u0947\u0902 \u0924\u0947\u091c\u0940 \u0938\u0947 \u092b\u0948\u0932 \u091c\u093e\u090f\u0917\u093e\u0964","tip.tipsmod.west.text":"\u0938\u0942\u0930\u094d\u092f, \u091a\u0902\u0926\u094d\u0930\u092e\u093e \u0914\u0930 \u0924\u093e\u0930\u0947 \u0938\u092c \u092a\u0936\u094d\u091a\u093f\u092e \u0915\u0940 \u0913\u0930 \u091a\u0932\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.swamp_slime.text":"\u092e\u0915\u094d\u0916\u093f\u092f\u093e\u0902 \u090f\u0915 \u092a\u0942\u0930\u094d\u0923 \u091a\u0902\u0926\u094d\u0930\u092e\u093e \u0915\u0947 \u0926\u094c\u0930\u093e\u0928 \u091d\u0940\u0932\u094b\u0902 \u092e\u0947\u0902 \u092a\u0948\u0926\u093e \u0939\u094b \u0938\u0915\u0924\u0940 \u0939\u0948\u0902\u0964","tip.tipsmod.deflect_ghast_fireballs.text":"\u0906\u092a \u0909\u0928 \u092a\u0930 \u0939\u092e\u0932\u093e \u0915\u0930\u0915\u0947 \u092d\u0942\u0924 \u092b\u093e\u092f\u0930\u092c\u0949\u0932 \u0915\u094b \u0926\u0942\u0930 \u0915\u0930 \u0938\u0915\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.shulker_armor.text":"\u0936\u0947\u0932\u0930\u094d\u0938 \u091c\u092c \u0909\u0928\u0915\u0947 \u0936\u0947\u0932 \u0916\u0941\u0932\u0947 \u0939\u094b\u0924\u0947 \u0939\u0948\u0902 \u0924\u094b \u0915\u093e\u092b\u0940 \u0905\u0927\u093f\u0915 \u0928\u0941\u0915\u0938\u093e\u0928 \u0909\u0920\u093e\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.arthropods.text":"\u0936\u094c\u0915\u093f\u092f\u093e, \u091a\u093e\u0902\u0926\u0940 \u0915\u0940 \u092e\u091b\u0932\u0940, \u092e\u0927\u0941\u092e\u0915\u094d\u0916\u0940, \u0914\u0930 \u090f\u0902\u0921\u0930\u092e\u093f\u091f\u094d\u0938 \u0938\u092d\u0940 \u0906\u0930\u094d\u0925\u094b\u092a\u094b\u0921 \u0915\u0947 \u092c\u0948\u0928 \u0938\u0947 \u0928\u0941\u0915\u0938\u093e\u0928 \u0932\u0947\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.fossils.text":"\u092c\u0921\u093c\u0947 \u0916\u0928\u093f\u091c \u091d\u0940\u0932\u094b\u0902 \u0914\u0930 \u0930\u0947\u0917\u093f\u0938\u094d\u0924\u093e\u0928\u094b\u0902 \u0915\u0947 \u0928\u0940\u091a\u0947 \u0926\u092b\u0928 \u0915\u093f\u090f \u091c\u093e\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.crouch_blocks.text":"\u0936\u094d\u0930\u0947\u0915\u093f\u0902\u0917/Crouching \u0906\u092a\u0915\u094b \u092c\u094d\u0932\u0949\u0915\u094b\u0902 \u0915\u0947 \u092a\u0915\u094d\u0937 \u0938\u0947 \u0917\u093f\u0930\u0928\u0947 \u0938\u0947 \u0930\u094b\u0915 \u0926\u0947\u0917\u093e\u0964","tip.tipsmod.smoke_bees.text":"\u090f\u0915 \u092e\u0927\u0941\u092e\u0915\u094d\u0916\u093f\u092f\u094b\u0902 \u0915\u0947 \u0918\u094b\u0902\u0938\u0932\u0947 \u0915\u0947 \u0928\u0940\u091a\u0947 \u090f\u0915 \u0915\u0948\u092e\u094d\u092a\u092b\u093e\u092f\u0930 \u0930\u0916\u0928\u093e \u0909\u0928 \u092e\u0927\u0941\u092e\u0915\u094d\u0916\u093f\u092f\u094b\u0902 \u0915\u094b \u0928\u093f\u0937\u094d\u0915\u094d\u0930\u093f\u092f \u092c\u0928\u093e \u0926\u0947\u0917\u093e\u0964","tip.tipsmod.lava_fuel.text":"\u0932\u093e\u0935\u093e \u092c\u0915\u094d\u0938\u0947 \u0915\u094b \u092b\u094b\u0930\u094d\u0928\u093f\u0938 \u092e\u0947\u0902 \u0908\u0902\u0927\u0928 \u0915\u0947 \u0930\u0942\u092a \u092e\u0947\u0902 \u0907\u0938\u094d\u0924\u0947\u092e\u093e\u0932 \u0915\u093f\u092f\u093e \u091c\u093e \u0938\u0915\u0924\u093e \u0939\u0948\u0964","tip.tipsmod.wooden_tool_fuel.text":"\u092a\u0941\u0930\u093e\u0928\u0947 \u0932\u0915\u0921\u093c\u0940 \u0915\u0947 \u0909\u092a\u0915\u0930\u0923\u094b\u0902 \u0915\u094b \u0913\u0935\u0928 \u092e\u0947\u0902 \u0908\u0902\u0927\u0928 \u0915\u0947 \u0930\u0942\u092a \u092e\u0947\u0902 \u0907\u0938\u094d\u0924\u0947\u092e\u093e\u0932 \u0915\u093f\u092f\u093e \u091c\u093e \u0938\u0915\u0924\u093e \u0939\u0948\u0964","tip.tipsmod.scrap_nuggets.text":"\u0938\u094b\u0928\u0947 \u0914\u0930 \u0932\u094b\u0939\u0947 \u0915\u0947 \u0909\u092a\u0915\u0930\u0923 / \u0939\u0925\u093f\u092f\u093e\u0930\u094b\u0902 \u0915\u094b \u0928\u093e\u0917\u0947\u091f \u092e\u0947\u0902 \u092a\u093f\u0918\u0932\u093e\u092f\u093e \u091c\u093e \u0938\u0915\u0924\u093e \u0939\u0948\u0964","tip.tipsmod.piglin_gold.text":"\u092e\u0942\u0930\u094d\u0916 \u0935\u093e\u0938\u094d\u0924\u0935 \u092e\u0947\u0902 \u0938\u094b\u0928\u0947 \u0938\u0947 \u092a\u094d\u092f\u093e\u0930 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.dog_health.text":"\u090f\u0915 \u0915\u0941\u0924\u094d\u0924\u0947 \u0915\u093e \u0915\u0942\u0921\u093c\u093e \u091c\u093f\u0924\u0928\u093e \u0915\u092e \u0939\u0948, \u0909\u0924\u0928\u093e \u0939\u0940 \u0915\u092e \u0938\u094d\u0935\u093e\u0938\u094d\u0925\u094d\u092f \u0909\u0928\u094d\u0939\u0947\u0902 \u091b\u094b\u0921\u093c \u0926\u093f\u092f\u093e \u0939\u0948\u0964","tip.tipsmod.dog_rotten_flesh.text":"\u0906\u092a \u0905\u092a\u0928\u0947 \u0915\u0941\u0924\u094d\u0924\u094b\u0902 \u0915\u094b \u0930\u094b\u091f\u0940 \u092e\u093e\u0902\u0938 \u0916\u093f\u0932\u093e\u0915\u0930 \u0920\u0940\u0915 \u0915\u0930 \u0938\u0915\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.lure_animals.text":"\u0906\u092a \u091c\u093e\u0928\u0935\u0930\u094b\u0902 \u0915\u094b \u0909\u0928 \u0916\u093e\u0926\u094d\u092f \u092a\u0926\u093e\u0930\u094d\u0925\u094b\u0902 \u0915\u094b \u092a\u0915\u0921\u093c\u0915\u0930 \u0906\u092a\u0915\u0947 \u092a\u0940\u091b\u0947 \u0932\u0947 \u091c\u093e \u0938\u0915\u0924\u0947 \u0939\u0948\u0902 \u091c\u093f\u0928\u094d\u0939\u0947\u0902 \u0935\u0947 \u092a\u0938\u0902\u0926 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.cooked_drops.text":"\u0906\u0917 \u0938\u0947 \u092e\u0930\u0928\u0947 \u0935\u093e\u0932\u0947 \u091c\u093e\u0928\u0935\u0930 \u0906\u092e\u0924\u094c\u0930 \u092a\u0930 \u092a\u0915\u093e\u092f\u093e \u092d\u094b\u091c\u0928 \u091b\u094b\u0921\u093c \u0926\u0947\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.nether_sponge.text":"\u0935\u0947\u091f \u0938\u094d\u092a\u0902\u091c \u0924\u0941\u0930\u0902\u0924 \u0938\u0942\u0916 \u091c\u093e\u090f\u0902\u0917\u0947 \u091c\u092c \u0935\u0947 \u0928\u0947\u091f \u092e\u0947\u0902 \u0930\u0916\u0947 \u091c\u093e\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.boat_passenger.text":"\u090f\u0915 \u091c\u0939\u093e\u091c \u0926\u094b \u092f\u093e\u0924\u094d\u0930\u093f\u092f\u094b\u0902 \u0915\u094b \u0932\u0947 \u0938\u0915\u0924\u093e \u0939\u0948\u0964","tip.tipsmod.note_block_instrument.text":"\u090f\u0915 \u0928\u094b\u091f \u092c\u094d\u0932\u0949\u0915 \u0915\u093e \u0909\u092a\u0915\u0930\u0923 \u0907\u0938\u0915\u0947 \u0928\u0940\u091a\u0947 \u0915\u0947 \u092c\u094d\u0932\u0949\u0915 \u0926\u094d\u0935\u093e\u0930\u093e \u0928\u093f\u0930\u094d\u0927\u093e\u0930\u093f\u0924 \u0915\u093f\u092f\u093e \u091c\u093e\u0924\u093e \u0939\u0948\u0964","tip.tipsmod.zombie_armor.text":"\u091c\u0949\u092c\u092e\u093f\u092f\u094b\u0902 \u0915\u0947 \u092a\u093e\u0938 \u092c\u0902\u0927\u0915 \u0915\u0947 \u0926\u094b \u0906\u0927\u093e\u0930 \u092c\u093f\u0902\u0926\u0941 \u0939\u0948\u0902, \u092f\u0939\u093e\u0902 \u0924\u0915 \u0915\u093f \u091c\u092c \u0935\u0947 \u0915\u093f\u0938\u0940 \u0915\u094b \u0928\u0939\u0940\u0902 \u092a\u0939\u0928\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.undead_helmet.text":"\u092e\u0943\u0924\u094d\u092f\u0941\u0913\u0902 \u0915\u094b \u0926\u093f\u0928 \u0915\u0940 \u0930\u094b\u0936\u0928\u0940 \u092e\u0947\u0902 \u091c\u0932\u093e \u0928\u0939\u0940\u0902 \u091c\u093e\u090f\u0917\u093e \u092f\u0926\u093f \u0935\u0947 \u090f\u0915 \u0939\u0947\u0932\u094d\u092e\u0947\u091f \u092a\u0939\u0928 \u0930\u0939\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.iron_golem_heal.text":"\u090f\u092f\u0930\u0928 \u0917\u094b\u0932\u0947\u092e \u0915\u094b \u0909\u0928\u094d\u0939\u0947\u0902 \u0906\u092f\u0930\u0928 \u0907\u0902\u0915 \u0926\u0947\u0915\u0930 \u0920\u0940\u0915 \u0915\u093f\u092f\u093e \u091c\u093e \u0938\u0915\u0924\u093e \u0939\u0948\u0964","tip.tipsmod.turtle_shell.text":"\u091f\u0930\u094d\u091f\u093f\u0902\u0917\u094d\u0938 \u0915\u0947\u0935\u0932 \u0924\u092c \u092b\u0947\u0902\u0915\u0924\u0947 \u0939\u0948\u0902 \u091c\u092c \u090f\u0915 \u092c\u091a\u094d\u091a\u093e \u090f\u0915 \u0935\u092f\u0938\u094d\u0915 \u092c\u0928 \u091c\u093e\u0924\u093e \u0939\u0948\u0964","tip.tipsmod.animal_growing.text":"\u092c\u091a\u094d\u091a\u0947 \u092a\u093e\u0932\u0924\u0942 \u091c\u093e\u0928\u0935\u0930\u094b\u0902 \u0915\u094b \u0916\u093f\u0932\u093e\u0928\u0947 \u0938\u0947 \u0935\u0947 \u091c\u0932\u094d\u0926\u0940 \u0938\u0947 \u092c\u0921\u093c\u0947 \u0939\u094b \u091c\u093e\u090f\u0902\u0917\u0947\u0964","tip.tipsmod.blaze_snowball.text":"\u092c\u094d\u0932\u0947\u091c\u093c \u092c\u0930\u094d\u092b \u0915\u0940 \u0917\u0947\u0902\u0926\u094b\u0902 \u0938\u0947 \u0915\u094d\u0937\u0924\u093f \u0932\u0947\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.biome_bonemeal.text":"\u0917\u094d\u0930\u093e\u0938 \u092c\u094d\u0932\u0949\u0915\u094b\u0902 \u092a\u0930 \u0939\u0921\u094d\u0921\u093f\u092f\u094b\u0902 \u0915\u0947 \u092d\u094b\u091c\u0928 \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0928\u093e \u0935\u093f\u092d\u093f\u0928\u094d\u0928 \u092a\u094d\u0930\u0915\u093e\u0930 \u0915\u0947 \u092b\u0942\u0932 \u0926\u0947 \u0938\u0915\u0924\u093e \u0939\u0948\u0964","tip.tipsmod.biome_fishing.text":"\u090f\u0915 \u091c\u0902\u0917\u0932 \u092e\u0947\u0902 \u092e\u091b\u0932\u0940 \u092a\u0915\u0921\u093c\u0928\u093e \u0906\u092a\u0915\u094b \u0905\u0928\u094d\u092f \u092c\u093e\u092f\u094b\u092e \u092e\u0947\u0902 \u092e\u091b\u0932\u0940 \u092a\u0915\u0921\u093c\u0928\u0947 \u0915\u0940 \u0924\u0941\u0932\u0928\u093e \u092e\u0947\u0902 \u0905\u0932\u0917-\u0905\u0932\u0917 \u0906\u0907\u091f\u092e \u0926\u0947 \u0938\u0915\u0924\u093e \u0939\u0948\u0964","tip.tipsmod.creeper_cat.text":"\u0915\u094d\u0930\u0947\u092a\u0930 \u092c\u093f\u0932\u094d\u0932\u093f\u092f\u094b\u0902 \u0938\u0947 \u0921\u0930\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u0909\u0928\u0938\u0947 \u092d\u093e\u0917\u0928\u0947 \u091c\u093e \u0930\u0939\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.water_grass.text":"\u092a\u093e\u0928\u0940 \u091c\u0932\u094d\u0926\u0940 \u0938\u0947 \u091