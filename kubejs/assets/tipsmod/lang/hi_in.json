\u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0915\u0947 \u0938\u093e\u092e\u093e\u0928\u094d\u092f \u0917\u0902\u0926\u0917\u0940 \u092e\u0947\u0902 \u092a\u0930\u093f\u0935\u0930\u094d\u0924\u093f\u0924 \u0915\u093f\u092f\u093e \u091c\u093e \u0938\u0915\u0924\u093e \u0939\u0948\u0964","tip.tipsmod.enderman_blocks.text":"\u0907\u0902\u0921\u0930\u092e\u0948\u0928 \u0917\u0902\u0926\u0917\u0940, \u0930\u0947\u0924 \u0914\u0930 \u091f\u0940\u090f\u0928\u091f\u0940 \u091c\u0948\u0938\u0947 \u092c\u094d\u0932\u0949\u0915\u094b\u0902 \u0915\u094b \u0938\u094d\u0925\u093e\u0928\u093e\u0902\u0924\u0930\u093f\u0924 \u0915\u0930 \u0938\u0915\u0924\u093e \u0939\u0948!","tip.tipsmod.piglin_repellent.text":"\u092e\u0942\u0930\u094d\u0916\u094b\u0902 \u0915\u094b \u0906\u0924\u094d\u092e\u093e \u0915\u0947 \u092b\u093e\u092f\u0930 \u092c\u094d\u0932\u0949\u0915 \u0938\u0947 \u0921\u0930\u0924\u093e \u0939\u0948, \u091c\u093f\u0938\u092e\u0947\u0902 \u0906\u0924\u094d\u092e\u093e \u091f\u0949\u0930\u094d\u091a \u0914\u0930 \u0906\u0924\u094d\u092e\u093e \u0932\u0948\u0902\u091f\u0930 \u0936\u093e\u092e\u093f\u0932 \u0939\u0948\u0902\u0964","tip.tipsmod.portal_trick.text":"\u092a\u093e\u0928\u0940 \u0914\u0930 \u0932\u093e\u0935\u093e \u092c\u0915\u094d\u0938\u0947 \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0915\u0947, \u0906\u092a \u090f\u0915 \u0906\u0938\u093e\u0928 \u0928\u0940\u091f\u0930 \u092a\u094b\u0930\u094d\u091f\u0932 \u092c\u0928\u093e \u0938\u0915\u0924\u0947 \u0939\u0948\u0902\u0964","tip.tipsmod.blaze_fuel.text":"\u092c\u094d\u0932\u0947\u091c\u093c \u0938\u094d\u091f\u0948\u0902\u0921 \u0913\u0935\u0928 \u0915\u0947 \u0932\u093f\u090f \u0905\u091a\u094d\u091b\u093e \u0908\u0902\u0927\u0928 \u0939\u0948\u0902\u0964","tip.tipsmod.goat_milk.text":"\u090f\u0915 \u092c\u0915\u0930\u0940 \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0915\u0947 \u092c\u0915\u0930\u0940 \u0915\u094b \u0926\u0942\u0927 \u0926\u093f\u092f\u093e \u091c