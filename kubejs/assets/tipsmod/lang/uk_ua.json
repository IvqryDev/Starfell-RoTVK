{"tipsmod.title.default":"\u041f\u043e\u0440\u0430\u0434\u0430","tip.tipsmod.undead_damage.text":"\u041d\u0435\u0436\u0438\u0442\u044c, \u044f\u043a-\u043e\u0442 \u0441\u043a\u0435\u043b\u0435\u0442\u0438, \u043e\u0442\u0440\u0438\u043c\u0443\u0454 \u0448\u043a\u043e\u0434\u0443 \u0432\u0456\u0434 \u0437\u0456\u043b\u043b\u0456\u0432 \u0437\u0446\u0456\u043b\u0435\u043d\u043d\u044f \u0442\u0430 \u0437\u0446\u0456\u043b\u044e\u0454\u0442\u044c\u0441\u044f \u0432\u0456\u0434 \u0437\u0456\u043b\u043b\u0456\u0432 \u0448\u043a\u043e\u0434\u0438.","tip.tipsmod.poison_immune.text":"\u0417\u043e\u043c\u0431\u0456, \u0441\u043a\u0435\u043b\u0435\u0442\u0438 \u0442\u0430 \u043f\u0430\u0432\u0443\u043a\u0438 \u043c\u0430\u044e\u0442\u044c \u0456\u043c\u0443\u043d\u0456\u0442\u0435\u0442 \u0434\u043e \u043e\u0442\u0440\u0443\u0454\u043d\u043d\u044f.","tip.tipsmod.witch_conversion.text":"\u0421\u0435\u043b\u044f\u043d\u0438\u043d \u0441\u0442\u0430\u0454 \u0432\u0456\u0434\u044c\u043c\u043e\u044e, \u043a\u043e\u043b\u0438 \u0432 \u043d\u044c\u043e\u0433\u043e \u0432\u043b\u0443\u0447\u0430\u0454 \u0431\u043b\u0438\u0441\u043a\u0430\u0432\u043a\u0430.","tip.tipsmod.four_eggs.text":"\u041f\u0456\u0441\u043b\u044f \u0440\u043e\u0437\u0431\u0438\u0442\u0442\u044f \u044f\u0439\u0446\u044f, \u0437 \u043d\u0435\u0432\u0435\u043b\u0438\u043a\u0438\u043c \u0448\u0430\u043d\u0441\u043e\u043c \u043c\u043e\u0436\u0435 \u0432\u0438\u043b\u0443\u043f\u0438\u0442\u0438\u0441\u044f 4 \u043a\u0443\u0440\u0447\u0430\u0442\u043a\u0430.","tip.tipsmod.nether_lava.text":"\u0423 \u041d\u0435\u0437\u0435\u0440\u0456 \u043b\u0430\u0432\u0430 \u0442\u0435\u0447\u0435 \u0448\u0432\u0438\u0434\u0448\u0435.","tip.tipsmod.west.text":"\u0421\u043e\u043d\u0446\u0435, \u041c\u0456\u0441\u044f\u0446\u044c \u0456 \u0437\u0456\u0440\u043a\u0438 \u0440\u0443\u0445\u0430\u044e\u0442\u044c\u0441\u044f \u043d\u0430 \u0437\u0430\u0445\u0456\u0434.","tip.tipsmod.swamp_slime.text":"\u0421\u043b\u0438\u043c\u0430\u043a\u0438 \u043c\u043e\u0436\u0443\u0442\u044c \u0437'\u044f\u0432\u043b\u044f\u0442\u0438\u0441\u044f \u043d\u0430 \u0431\u043e\u043b\u043e\u0442\u0430\u0445 \u043f\u0456\u0434 \u0447\u0430\u0441 \u043f\u043e\u0432\u043d\u043e\u0433\u043e \u043c\u0456\u0441\u044f\u0446\u044f.","tip.tipsmod.deflect_ghast_fireballs.text":"\u0412\u0438 \u043c\u043e\u0436\u0435\u0442\u0435 \u0432\u0456\u0434\u0431\u0438\u0442\u0438 \u0437\u0430\u0440\u044f\u0434 \u043f\u043e\u043b\u0443\u043c'\u044f \u0491\u0430\u0441\u0442\u0430, \u0432\u0434\u0430\u0440\u0438\u0432\u0448\u0438 \u043f\u043e \u043d\u044c\u043e\u043c\u0443.","tip.tipsmod.shulker_armor.text":"\u0428\u0430\u043b\u043a\u0435\u0440\u0438 \u043e\u0442\u0440\u0438\u043c\u0443\u044e\u0442\u044c \u0437\u043d\u0430\u0447\u043d\u043e \u0431\u0456\u043b\u044c\u0448\u0435 \u0448\u043a\u043e\u0434\u0438, \u043a\u043e\u043b\u0438 \u0457\u0445\u043d\u0456 \u0440\u0430\u043a\u0443\u0448\u043d\u044f\u043a\u0438 \u0432\u0456\u0434\u043a\u0440\u0438\u0442\u0456.","tip.tipsmod.arthropods.text":"\u041f\u0430\u0432\u0443\u043a\u0438, \u043b\u0443\u0441\u043a\u0456\u0432\u043d\u0438\u0446\u0456, \u0431\u0434\u0436\u043e\u043b\u0438 \u0442\u0430 \u0435\u043d\u0434\u0435\u0440\u043c\u0456\u0442\u0438 \u043e\u0442\u0440\u0438\u043c\u0443\u044e\u0442\u044c \u0448\u043a\u043e\u0434\u0443 \u0432\u0456\u0434 \u0437\u0430\u0447\u0430\u0440\u0443\u0432\u0430\u043d\u043d\u044f \u00ab\u0417\u0430\u0433\u0438\u0431\u0435\u043b\u044c \u0447\u043b\u0435\u043d\u0438\u0441\u0442\u043e\u043d\u043e\u0433\u0438\u0445\u00bb.","tip.tipsmod.fossils.text":"\u041f\u0456\u0434 \u0431\u043e\u043b\u043e\u0442\u0430\u043c\u0438 \u0442\u0430 \u043f\u0443\u0441\u0442\u0435\u043b\u044f\u043c\u0438 \u0437\u0430\u043a\u043e\u043f\u0430\u043d\u0456 \u0432\u0435\u043b\u0438\u043a\u0456 \u0441\u043a\u0430\u043c'\u044f\u043d\u0456\u043b\u043e\u0441\u0442\u0456.","tip.tipsmod.crouch_blocks.text":"\u041f\u0440\u0438\u0441\u044f\u0434\u044c\u0442\u0435, \u0449\u043e\u0431 \u043d\u0435 \u043f\u0430\u0434\u0430\u0442\u0438 \u0437 \u0431\u043e\u043a\u0456\u0432 \u0431\u043b\u043e\u043a\u0443.","tip.tipsmod.smoke_bees.text":"\u0420\u043e\u0437\u043c\u0456\u0449\u0435\u043d\u043d\u044f \u0431\u0430\u0433\u0430\u0442\u0442\u044f \u043f\u0456\u0434 \u0431\u0434\u0436\u043e\u043b\u0438\u043d\u0438\u043c \u0433\u043d\u0456\u0437\u0434\u043e\u043c \u0437\u0440\u043e\u0431\u0438\u0442\u044c \u0446\u0438\u0445 \u0431\u0434\u0436\u0456\u043b \u043f\u0430\u0441\u0438\u0432\u043d\u0438\u043c\u0438.","tip.tipsmod.lava_fuel.text":"\u0412\u0456\u0434\u0440\u0430 \u043b\u0430\u0432\u0438 \u043c\u043e\u0436\u043d\u0430 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u044f\u043a \u043f\u0430\u043b\u0438\u0432\u043e \u0434\u043b\u044f \u043f\u0435\u0447\u0456.","tip.tipsmod.wooden_tool_fuel.text":"\u0421\u0442\u0430\u0440\u0456 \u0434\u0435\u0440\u0435\u0432'\u044f\u043d\u0456 \u0456\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u0438 \u043c\u043e\u0436\u043d\u0430 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u044f\u043a \u043f\u0430\u043b\u0438\u0432\u043e \u0434\u043b\u044f \u043f\u0435\u0447\u0456.","tip.tipsmod.scrap_nuggets.text":"\u0417\u043e\u043b\u043e\u0442\u0456 \u0442\u0430 \u0437\u0430\u043b\u0456\u0437\u043d\u0456 \u0456\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u0438/\u043e\u0431\u043b\u0430\u0434\u0443\u043d\u043a\u0438 \u043c\u043e\u0436\u043d\u0430 \u043f\u0435\u0440\u0435\u043f\u043b\u0430\u0432\u0438\u0442\u0438 \u043d\u0430 \u0441\u0430\u043c\u043e\u0440\u043e\u0434\u043a\u0438.","tip.tipsmod.piglin_gold.text":"\u041f\u0456\u0491\u043b\u0456\u043d\u0438 \u0434\u0443\u0436\u0435 \u043b\u044e\u0431\u043b\u044f\u0442\u044c \u0437\u043e\u043b\u043e\u0442\u043e.","tip.tipsmod.dog_health.text":"\u0427\u0438\u043c \u043d\u0438\u0436\u0447\u0435 \u0445\u0432\u0456\u0441\u0442 \u0443 \u0441\u043e\u0431\u0430\u043a\u0438, \u0442\u0438\u043c \u043c\u0435\u043d\u0448\u0435 \u0432 \u043d\u0435\u0457 \u0437\u0430\u043b\u0438\u0448\u0438\u043b\u043e\u0441\u044f \u0437\u0434\u043e\u0440\u043e\u0432'\u044f.","tip.tipsmod.dog_rotten_flesh.text":"\u0412\u0438 \u043c\u043e\u0436\u0435\u0442\u0435 \u0437\u0446\u0456\u043b\u0438\u0442\u0438 \u0441\u0432\u043e\u0457\u0445 \u0441\u043e\u0431\u0430\u043a, \u0433\u043e\u0434\u0443\u044e\u0447\u0438 \u0457\u0445 \u0433\u043d\u0438\u043b\u043e\u044e \u043f\u043b\u043e\u0442\u0442\u044e.","tip.tipsmod.lure_animals.text":"\u0412\u0438 \u043c\u043e\u0436\u0435\u0442\u0435 \u0437\u0430\u043c\u0430\u043d\u0438\u0442\u0438 \u0442\u0432\u0430\u0440\u0438\u043d \u0441\u043b\u0456\u0434\u0443\u0432\u0430\u0442\u0438 \u0437\u0430 \u0432\u0430\u043c\u0438, \u0442\u0440\u0438\u043c\u0430\u044e\u0447\u0438 \u0457\u0436\u0443, \u044f\u043a\u0430 \u0457\u043c \u043f\u043e\u0434\u043e\u0431\u0430\u0454\u0442\u044c\u0441\u044f.","tip.tipsmod.cooked_drops.text":"\u0417 \u0442\u0432\u0430\u0440\u0438\u043d, \u0443\u0431\u0438\u0442\u0438\u0445 \u0432\u043e\u0433\u043d\u0435\u043c, \u0437\u0430\u0437\u0432\u0438\u0447\u0430\u0439 \u0432\u0438\u043f\u0430\u0434\u0430\u0454 \u0441\u043c\u0430\u0436\u0435\u043d\u0430 \u0457\u0436\u0430.","tip.tipsmod.nether_sponge.text":"\u041c\u043e\u043a\u0440\u0456 \u0433\u0443\u0431\u043a\u0438 \u0432\u0456\u0434\u0440\u0430\u0437\u0443 \u0432\u0438\u0441\u0438\u0445\u0430\u044e\u0442\u044c, \u044f\u043a\u0449\u043e \u0457\u0445 \u0440\u043e\u0437\u043c\u0456\u0441\u0442\u0438\u0442\u0438 \u0432 \u041d\u0435\u0437\u0435\u0440\u0456.","tip.tipsmod.boat_passenger.text":"\u0427\u043e\u0432\u043d\u0438 \u043c\u043e\u0436\u0443\u0442\u044c \u043f\u0435\u0440\u0435\u0432\u043e\u0437\u0438\u0442\u0438 \u0434\u043e \u0434\u0432\u043e\u0445 \u043f\u0430\u0441\u0430\u0436\u0438\u0440\u0456\u0432.","tip.tipsmod.note_block_instrument.text":"\u0406\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442 \u043d\u043e\u0442\u043d\u043e\u0433\u043e \u0431\u043b\u043e\u043a\u0443 \u0432\u0438\u0437\u043d\u0430\u0447\u0430\u0454\u0442\u044c\u0441\u044f \u0431\u043b\u043e\u043a\u043e\u043c, \u0449\u043e \u0437\u043d\u0430\u0445\u043e\u0434\u0438\u0442\u044c\u0441\u044f \u043f\u0456\u0434 \u043d\u0438\u043c.","tip.tipsmod.zombie_armor.text":"\u0417\u043e\u043c\u0431\u0456 \u043c\u0430\u044e\u0442\u044c \u0434\u0432\u0456 \u0431\u0430\u0437\u043e\u0432\u0456 \u043e\u0434\u0438\u043d\u0438\u0446\u0456 \u0431\u0440\u043e\u043d\u0456, \u043d\u0430\u0432\u0456\u0442\u044c \u044f\u043a\u0449\u043e \u043d\u0430 \u043d\u0438\u0445 \u043d\u0435\u043c\u0430\u0454 \u0436\u043e\u0434\u043d\u043e\u0457.","tip.tipsmod.undead_helmet.text":"\u041d\u0435\u0436\u0438\u0442\u044c \u043d\u0435 \u0433\u043e\u0440\u0438\u0442\u044c \u043f\u0440\u0438 \u0434\u0435\u043d\u043d\u043e\u043c\u0443 \u0441\u0432\u0456\u0442\u043b\u0456, \u044f\u043a\u0449\u043e \u043d\u0430 \u043d\u0456\u0439 \u0454 \u0448\u043e\u043b\u043e\u043c.","tip.tipsmod.iron_golem_heal.text":"\u0417\u0430\u043b\u0456\u0437\u043d\u0438\u0445 \u0491\u043e\u043b\u0435\u043c\u0456\u0432 \u043c\u043e\u0436\u043d\u0430 \u0437\u0446\u0456\u043b\u0438\u0442\u0438, \u0434\u0430\u0432\u0448\u0438 \u0457\u043c \u0437\u0430\u043b\u0456\u0437\u043d\u0456 \u0437\u043b\u0438\u0442\u043a\u0438.","tip.tipsmod.turtle_shell.text":"\u0427\u0435\u0440\u0435\u043f\u0430\u0445\u0438 \u0441\u043a\u0438\u0434\u0430\u044e\u0442\u044c \u0447\u0435\u0440\u0435\u043f\u043a\u0438 \u0442\u0456\u043b\u044c\u043a\u0438 \u0442\u043e\u0434\u0456, \u043a\u043e\u043b\u0438 \u0432\u0438\u0440\u043e\u0441\u0442\u0430\u0454 \u0434\u0438\u0442\u0438\u043d\u0430.","tip.tipsmod.animal_growing.text":"\u0413\u043e\u0434\u0443\u0432\u0430\u043d\u043d\u044f \u0434\u0438\u0442\u0438\u043d\u0447\u0430\u0442 \u0442\u0432\u0430\u0440\u0438\u043d \u043f\u0440\u0438\u0448\u0432\u0438\u0434\u0448\u0443\u0454 \u0457\u0445\u043d\u0454 \u0437\u0440\u043e\u0441\u0442\u0430\u043d\u043d\u044f.","tip.tipsmod.blaze_snowball.text":"\u041f\u043b\u043e\u043c\u0435\u043d\u0456 \u043e\u0442\u0440\u0438\u043c\u0443\u044e\u0442\u044c \u0448\u043a\u043e\u0434\u0443 \u0432\u0456\u0434 \u0441\u043d\u0456\u0436\u043e\u043a.","tip.tipsmod.biome_bonemeal.text":"\u0412\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u0430\u043d\u043d\u044f \u043a\u0456\u0441\u0442\u043a\u043e\u0432\u043e\u0433\u043e \u0431\u043e\u0440\u043e\u0448\u043d\u0430 \u043d\u0430 \u0431\u043b\u043e\u0446\u0456 \u0442\u0440\u0430\u0432\u0438 \u043c\u043e\u0436\u0435 \u0432\u0438\u0440\u043e\u0441\u0442\u0438\u0442\u0438 \u0440\u0456\u0437\u043d\u0456 \u0432\u0438\u0434\u0438 \u043a\u0432\u0456\u0442\u0456\u0432.","tip.tipsmod.biome_fishing.text":"\u0420\u0438\u0431\u043e\u043b\u043e\u0432\u043b\u044f \u0432 \u0434\u0436\u0443\u043d\u0433\u043b\u044f\u0445 \u043c\u043e\u0436\u0435 \u0434\u0430\u0442\u0438 \u0432\u0430\u043c \u0434\u0435\u044f\u043a\u0456 \u043f\u0440\u0435\u0434\u043c\u0435\u0442\u0438, \u044f\u043a\u0456 \u043d\u0435 \u0437\u0443\u0441\u0442\u0440\u0456\u0447\u0430\u044e\u0442\u044c\u0441\u044f \u0432 \u0436\u043e\u0434\u043d\u043e\u043c\u0443 \u0456\u043d\u0448\u043e\u043c\u0443 \u0431\u0456\u043e\u043c\u0456.","tip.tipsmod.creeper_cat.text":"\u041a\u0440\u0456\u043f\u0435\u0440\u0438 \u0431\u043e\u044f\u0442\u044c\u0441\u044f \u043a\u043e\u0442\u0456\u0432 \u0456 \u0431\u0443\u0434\u0443\u0442\u044c \u0432\u0456\u0434 \u043d\u0438\u0445 \u0442\u0456\u043a\u0430\u0442\u0438.","tip.tipsmod.water_grass.text":"\u0417\u0430 \u0434\u043e\u043f\u043e\u043c\u043e\u0433\u043e\u044e \u0432\u043e\u0434\u0438 \u043c\u043e\u0436\u043d\u0430 \u0448\u0432\u0438\u0434\u043a\u043e \u0437\u043d\u0438\u0449\u0443\u0432\u0430\u0442\u0438 \u0442\u0440\u0430\u0432\u0443 \u0434\u043b\u044f \u043e\u0442\u0440\u0438\u043c\u0430\u043d\u043d\u044f \u043d\u0430\u0441\u0456\u043d\u043d\u044f.","tip.tipsmod.gravity_torch.text":"\u041f\u0440\u0438 \u043f\u0430\u0434\u0456\u043d\u043d\u0456 \u043d\u0430 \u0441\u043c\u043e\u043b\u043e\u0441\u043a\u0438\u043f, \u043f\u0430\u0434\u0430\u044e\u0447\u0456 \u0431\u043b\u043e\u043a\u0438, \u044f\u043a-\u043e\u0442 \u043f\u0456\u0441\u043e\u043a \u0442\u0430 \u0433\u0440\u0430\u0432\u0456\u0439, \u043c\u0438\u0442\u0442\u0454\u0432\u043e \u0437\u043d\u0438\u0449\u0443\u044e\u0442\u044c\u0441\u044f.","tip.tipsmod.string_wool.text":"\u0412\u043e\u0432\u043d\u0443 \u043c\u043e\u0436\u043d\u0430 \u0432\u0438\u0433\u043e\u0442\u043e\u0432\u0438\u0442\u0438 \u0437\u0430 \u0434\u043e\u043f\u043e\u043c\u043e\u0433\u043e\u044e \u0447\u043e\u0442\u0438\u0440\u044c\u043e\u0445 \u043d\u0438\u0442\u043e\u043a, \u0440\u043e\u0437\u043c\u0456\u0449\u0435\u043d\u0438\u0445 \u043d\u0430 \u0441\u0456\u0442\u0446\u0456 \u043c\u0430\u0439\u0441\u0442\u0440\u0443\u0432\u0430\u043d\u043d\u044f 2x2.","tip.tipsmod.barrel.text":"\u0414\u0456\u0436\u043a\u0438 \u2013 \u0437\u0440\u0443\u0447\u043d\u0430 \u0430\u043b\u044c\u0442\u0435\u0440\u043d\u0430\u0442\u0438\u0432\u0430 \u0441\u043a\u0440\u0438\u043d\u044f\u043c.","tip.tipsmod.job_site_dimension.text":"\u0421\u0435\u043b\u044f\u043d\u0438\u043d\u0438 \u0432\u0442\u0440\u0430\u0447\u0430\u044e\u0442\u044c \u043c\u0456\u0441\u0446\u0435 \u0440\u043e\u0431\u043e\u0442\u0438 \u043f\u0440\u0438 \u043f\u0435\u0440\u0435\u043c\u0456\u0449\u0435\u043d\u043d\u0456 \u043c\u0456\u0436 \u0432\u0438\u043c\u0456\u0440\u0430\u043c\u0438.","tip.tipsmod.wandering_invis.text":"\u041c\u0430\u043d\u0434\u0440\u0456\u0432\u043d\u0456 \u0442\u043e\u0440\u0433\u043e\u0432\u0446\u0456 \u0432\u043d\u043e\u0447\u0456 \u043f'\u044e\u0442\u044c \u0437\u0456\u043b\u043b\u044f \u043d\u0435\u0432\u0438\u0434\u0438\u043c\u043e\u0441\u0442\u0438.","tip.tipsmod.baby_panda_slimeball.text":"\u0414\u0438\u0442\u0438\u043d\u0447\u0430\u0442\u0430 \u043f\u0430\u043d\u0434\u0438 \u043c\u0430\u044e\u0442\u044c 0.1% \u0448\u0430\u043d\u0441 \u0441\u043a\u0438\u043d\u0443\u0442\u0438 \u0441\u043b\u0438\u0437\u043e\u0432\u0443 \u043a\u0443\u043b\u044c\u043a\u0443 \u043f\u0456\u0441\u043b\u044f \u0447\u0445\u0430\u043d\u043d\u044f.","tip.tipsmod.fortress_triangulation.text":"\u0412\u0438 \u043c\u043e\u0436\u0435\u0442\u0435 \u0432\u0438\u0437\u043d\u0430\u0447\u0438\u0442\u0438 \u0440\u043e\u0437\u0442\u0430\u0448\u0443\u0432\u0430\u043d\u043d\u044f \u0442\u0432\u0435\u0440\u0434\u0438\u043d\u0456, \u043a\u0438\u043d\u0443\u0432\u0448\u0438 \u043e\u0447\u0456 \u0415\u043d\u0434\u0443 \u0437 \u0434\u0432\u043e\u0445 \u0440\u0456\u0437\u043d\u0438\u0445 \u043c\u0456\u0441\u0446\u044c \u0456 \u0432\u0438\u0437\u043d\u0430\u0447\u0438\u0432\u0448\u0438 \u0442\u043e\u0447\u043a\u0443 \u043f\u0435\u0440\u0435\u0442\u0438\u043d\u0443.","tip.tipsmod.creeper_drops_disc.text":"\u042f\u043a\u0449\u043e \u0441\u0442\u0440\u0456\u043b\u0430 \u0441\u043a\u0435\u043b\u0435\u0442\u0430 \u0430\u0431\u043e \u043f\u0440\u0438\u043c\u0430\u0440\u0438 \u0432\u0431\u0438\u0432\u0430\u0454 \u043a\u0440\u0456\u043f\u0435\u0440\u0430, \u0442\u043e \u0437 \u043d\u044c\u043e\u0433\u043e \u0432\u0438\u043f\u0430\u0434\u0430\u0454 \u0432\u0438\u043f\u0430\u0434\u043a\u043e\u0432\u0430 \u043f\u043b\u0430\u0442\u0456\u0432\u043a\u0430.","tip.tipsmod.mooshroom_lightning.text":"\u0412\u043b\u0443\u0447\u0430\u043d\u043d\u044f \u0431\u043b\u0438\u0441\u043a\u0430\u0432\u043a\u0438 \u0432 \u0447\u0435\u0440\u0432\u043e\u043d\u0438\u0439 \u0433\u0440\u0438\u0431 \u043f\u0435\u0440\u0435\u0442\u0432\u043e\u0440\u0438\u0442\u044c \u0439\u043e\u0433\u043e \u043d\u0430 \u043a\u043e\u0440\u0438\u0447\u043d\u0435\u0432\u0438\u0439, \u0430 \u043a\u043e\u0440\u0438\u0447\u043d\u0435\u0432\u0438\u0439 \u2014 \u043d\u0430 \u0447\u0435\u0440\u0432\u043e\u043d\u0438\u0439.","tip.tipsmod.bed_explode.text":"\u0421\u043f\u0440\u043e\u0431\u0430 \u043f\u043e\u0441\u043f\u0430\u0442\u0438 \u0432 \u0456\u043d\u0448\u0438\u0445 \u0432\u0438\u043c\u0456\u0440\u0430\u0445 \u0437\u0430\u043a\u0456\u043d\u0447\u0438\u0442\u044c\u0441\u044f \u043f\u043b\u0430\u0447\u0435\u0432\u043d\u043e.","tip.tipsmod.fall_damage_blocks.text":"\u0414\u0435\u044f\u043a\u0456 \u0431\u043b\u043e\u043a\u0438, \u044f\u043a-\u043e\u0442 \u0432\u043e\u0434\u0430 \u0442\u0430 \u0441\u0456\u043d\u043e, \u043c\u043e\u0436\u0443\u0442\u044c \u0437\u043c\u0435\u043d\u0448\u0438\u0442\u0438 \u0448\u043a\u043e\u0434\u0443 \u0432\u0456\u0434 \u043f\u0430\u0434\u0456\u043d\u043d\u044f.","tip.tipsmod.bed_respawn.text":"\u0421\u043e\u043d \u0443 \u043b\u0456\u0436\u043a\u0443 \u0432\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u044c \u0432\u0430\u0448\u0443 \u0442\u043e\u0447\u043a\u0443 \u043f\u043e\u044f\u0432\u0438.","tip.tipsmod.ore_tiers.text":"\u0414\u0435\u044f\u043a\u0456 \u0440\u0443\u0434\u0438 \u043c\u0430\u044e\u0442\u044c \u043c\u0456\u043d\u0456\u043c\u0430\u043b\u044c\u043d\u043e \u043d\u0435\u043e\u0431\u0445\u0456\u0434\u043d\u0438\u0439 \u0440\u0456\u0432\u0435\u043d\u044c \u043a\u0430\u0439\u043b\u0430 \u0434\u043b\u044f \u0457\u0445 \u0432\u0438\u0434\u043e\u0431\u0443\u0442\u043a\u0443.","tip.tipsmod.sponge_bucket.text":"\u041c\u043e\u043a\u0440\u0443 \u0433\u0443\u0431\u043a\u0443 \u043c\u043e\u0436\u043d\u0430 \u0432\u0438\u0441\u0443\u0448\u0438\u0442\u0438, \u043f\u0440\u0438\u0433\u043e\u0442\u0443\u0432\u0430\u0432\u0448\u0438 \u0457\u0457 \u0432 \u043f\u0435\u0447\u0456. \u042f\u043a\u0449\u043e \u0432 \u0441\u043b\u043e\u0442\u0456 \u0434\u043b\u044f \u043f\u0430\u043b\u0438\u0432\u0430 \u0454 \u043f\u043e\u0440\u043e\u0436\u043d\u0454 \u0432\u0456\u0434\u0440\u043e, \u0432\u043e\u043d\u043e \u0431\u0443\u0434\u0435 \u043d\u0430\u043f\u043e\u0432\u043d\u0435\u043d\u0435 \u0432\u043e\u0434\u043e\u044e!","tip.tipsmod.coarse_to_dirt.text":"\u0417\u0430\u0433\u0440\u0443\u0431\u0456\u043b\u0438\u0439 \u0491\u0440\u0443\u043d\u0442 \u043c\u043e\u0436\u043d\u0430 \u043f\u0435\u0440\u0435\u0442\u0432\u043e\u0440\u0438\u0442\u0438 \u043d\u0430 \u0437\u0432\u0438\u0447\u0430\u0439\u043d\u0438\u0439 \u0437\u0430 \u0434\u043e\u043f\u043e\u043c\u043e\u0433\u043e\u044e \u043c\u043e\u0442\u0438\u043a\u0438.","tip.tipsmod.enderman_blocks.text":"\u0415\u043d\u0434\u0435\u0440\u043c\u0435\u043d \u043c\u043e\u0436\u0435 \u043f\u0435\u0440\u0435\u043c\u0456\u0449\u0430\u0442\u0438 \u0431\u043b\u043e\u043a\u0438, \u0442\u0430\u043a\u0456 \u044f\u043a \u0491\u0440\u0443\u043d\u0442, \u043f\u0456\u0441\u043e\u043a \u0456 \u0434\u0438\u043d\u0430\u043c\u0456\u0442!","tip.tipsmod.piglin_repellent.text":"\u041f\u0456\u0491\u043b\u0456\u043d\u0438 \u0431\u043e\u044f\u0442\u044c\u0441\u044f \u043f\u043e\u043b\u0443\u043c'\u044f \u0434\u0443\u0448, \u0437\u043e\u043a\u0440\u0435\u043c\u0430 \u0443 \u0432\u0438\u0433\u043b\u044f\u0434\u0456 \u043b\u0456\u0445\u0442\u0430\u0440\u0456\u0432 \u0442\u0430 \u0441\u043c\u043e\u043b\u043e\u0441\u043a\u0438\u043f\u0456\u0432.","tip.tipsmod.portal_trick.text":"\u0412\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u044e\u0447\u0438 \u0432\u0456\u0434\u0440\u0430 \u0437 \u0432\u043e\u0434\u043e\u044e \u0442\u0430 \u043b\u0430\u0432\u043e\u044e, \u0432\u0438 \u043c\u043e\u0436\u0435\u0442\u0435 \u043b\u0435\u0433\u043a\u043e \u0437\u0440\u043e\u0431\u0438\u0442\u0438 \u043f\u043e\u0440\u0442\u0430\u043b \u0443 \u041d\u0435\u0437\u0435\u0440.","tip.tipsmod.blaze_fuel.text":"\u0421\u0442\u0440\u0438\u0436\u043d\u0456 \u043f\u043b\u043e\u043c\u0435\u043d\u044f \u0454 \u0445\u043e\u0440\u043e\u0448\u0438\u043c \u043f\u0430\u043b\u0438\u0432\u043e\u043c \u0434\u043b\u044f \u043f\u0435\u0447\u0456.","tip.tipsmod.goat_milk.text":"\u041a\u0456\u0437 \u043c\u043e\u0436\u043d\u0430 \u043f\u043e\u0434\u043e\u0457\u0442\u0438 \u0437\u0430 \u0434\u043e\u043f\u043e\u043c\u043e\u0433\u043e\u044e \u0432\u0456\u0434\u0440\u0430.","tip.tipsmod.mean_goats.text":"\u0411\u0443\u0434\u044c\u0442\u0435 \u043e\u0431\u0435\u0440\u0435\u0436\u043d\u0456 \u0437 \u043a\u043e\u0437\u0430\u043c\u0438. \u0412\u043e\u043d\u0438 \u043b\u044e\u0431\u043b\u044f\u0442\u044c \u0441\u043a\u0438\u0434\u0443\u0432\u0430\u0442\u0438 \u0433\u0440\u0430\u0432\u0446\u0456\u0432